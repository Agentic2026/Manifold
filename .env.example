# ── Manifold environment ────────────────────────────────────
# Copy to .env and adjust as needed.
# ────────────────────────────────────────────────────────────

# --- Deployment / public origin ---
# WEB_PORT controls the single public port exposed by the Caddy web container.
WEB_PORT=8080

# h4ckath0n framework
H4CKATH0N_ENV=development
H4CKATH0N_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/manifold
H4CKATH0N_RP_ID=localhost
H4CKATH0N_ORIGIN=http://localhost:8080
H4CKATH0N_APP_BASE_URL=http://localhost:8080
H4CKATH0N_REDIS_URL=
H4CKATH0N_STORAGE_DIR=./.h4ckath0n_storage
H4CKATH0N_EMAIL_BACKEND=file
H4CKATH0N_EMAIL_OUTBOX_DIR=./.h4ckath0n_email_outbox
H4CKATH0N_DEMO_MODE=false
H4CKATH0N_PASSWORD_AUTH_ENABLED=true

# OpenAI (optional – deep scan & LLM insights only)
OPENAI_API_KEY=

# Frontend API base (relative to public origin – proxied through Caddy)
VITE_API_BASE_URL=/api

# Manifold backend
CADVISOR_METRICS_API_TOKEN=my-secret-token

# --- Image overrides (optional) ---
# MANIFOLD_IMAGE=ghcr.io/agentic2026/manifold:latest
# MANIFOLD_WEB_IMAGE=ghcr.io/agentic2026/manifold-web:latest
